<script>
    // List of partner logo image paths
    // These images will be displayed one after another in a loop
    const logos = [
        "/images/partners/credit-agricole.jpg",
        "/images/partners/actimage.jpg",
        "/images/partners/xlim.jpg"
    ];

    // Current index of the logo being displayed
    let index = 0;

    // Get the <img> element from the DOM where logos will be displayed
    const img = document.getElementById("partnerLogo");

    // Execute the function every 1 second (1000ms)
    setInterval(() => {  

        // Move to the next logo in the array
        // The modulo (%) ensures the index loops back to 0 when reaching the end
        index = (index + 1) % logos.length;

        // Start fade-out effect by reducing opacity
        img.style.opacity = 0;

        // Wait 300 milliseconds before changing the image (to allow fade-out effect)
        setTimeout(() => {

            // Change the image source to the next logo
            img.src = logos[index];

            // Fade the image back in
            img.style.opacity = 1;

        }, 300);

    }, 1000); // Repeat this process every 1 second
</script>


</body>
