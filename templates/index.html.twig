<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ name }} - Portfolio</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #f4f4f4;
            color: #333;
        }

        header {
            background: #222;
            color: #fff;
            padding: 20px;
            text-align: center;
        }

        .container {
            width: 80%;
            margin: auto;
            padding: 20px;
        }

        .profile {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .photo {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background-size: cover;
            background-position: center;
        }

        .linkedin a {
            color: #0077b5;
            text-decoration: none;
            font-weight: bold;
        }

        .services, .projects {
            margin-top: 30px;
        }

        .card {
            background: white;
            padding: 15px;
            margin-top: 10px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        /* .certifications-btn {
            display: inline-block;
            margin: 40px auto;
            padding: 12px 28px;
            background: linear-gradient(135deg, #007BFF, #0056b3);
            color: #ffffff;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            border-radius: 8px;
            text-align: center;
            transition: all 0.3s ease;
            box-shadow: 0 4px 10px rgba(0, 123, 255, 0.3);
        }  */

        .certifications-btn { 
            position: absolute;  
            top: 120px;       
            left: 575px;    
            padding: 6px 10px; 
            background: linear-gradient(135deg, #007BFF, #0056b3); 
            color: white;  
            text-decoration: none;        
            border-radius: 6px;    
            font-weight: bold;  
            font-size: 14px;   
            transition: 0.3s;   
   
        }       


        .certifications-btn:hover {
            background: linear-gradient(135deg, #0056b3, #003f7f);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0, 123, 255, 0.4);
        }

        .certifications-btn:active {
            transform: translateY(0);
            box-shadow: 0 3px 8px rgba(0, 123, 255, 0.3);
        }

        footer {
            margin-top: 40px;
            padding: 20px;
            text-align: center;
            background: #222;
            color: white;
        }
    </style>
</head>

<body>

<header>
    <h1>{{ name }}</h1>
    <p>{{ title }}</p>
</header>
 
<div class="container">

    <div class="profile">
        <!-- Professional Photo -->
        <div class="photo" style="background-image: url('{{ photo }}');">
        </div>

        <!-- LinkedIn -->
        <div class="linkedin">
            <p>Connect with me :</p>
            <a href="{{ linkedin }}" target="_blank">My LinkedIn Profile</a>   
                  
        </div>    

    
    </div>       
  
    <div class="services">
        <h2>My Services</h2>

        <div class="card">
            <h3>Web Development</h3>
            <p>Creations of robust web applications with Symfony, Laravel, Node.js, Vue.js and artificial intelligences.</p>
            <p>Whatever your ideas, it will be a pleasure to enhance with you, the profit of your company.</p>   
        </div>          
  
        <div class="card"> 
            <h3>API Development</h3>
            <p>Designing and integrating RESTful APIs and complex API such as STRIPE.</p>
        </div>
    
        <div class="card">   
            <h3>Maintenance & Optimization</h3>
            <p>Improving performance and maintaining existing applications.</p>
        </div>
    </div>

    <div class="projects"> 
        <h2>My Work</h2>
        <p>
            RESEAU PRO : 
            <a href="https://recruteurs.reseaupro.unif.fr/" target="_blank">
                https://recruteurs.reseaupro.unif.fr/
            </a>
        </p>   
    </div>  

    <div> 
    <a href="{{ path('certifications_route') }}" class="certifications-btn">
        List of my certifications, awards and honors 🏆  
    </a>  

    </div>         

</div>   

<footer>
    <p>© {{ "now"|date("Y") }} {{ name }}</p>
</footer>

</body>
</html>